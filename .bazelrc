# Use local Python toolchain from venv
build --action_env=PYTHONPATH=
build --action_env=PYTHONNOUSERSITE=1

# Register cross-compilation toolchains
build --extra_toolchains=//toolchains/arm64-linux-gnu/orin-nano:orin_nano_toolchain
build --extra_toolchains=//toolchains/arm-linux-gnueabihf/bbb:bbb_cc_toolchain

# Custom build configurations
# ARM64 build for NVIDIA Orin Nano
build:orin-nano --platforms=//toolchains:linux_aarch64
build:orin-nano --extra_toolchains=//toolchains/arm64-linux-gnu/orin-nano:orin_nano_toolchain
build:orin-nano --spawn_strategy=local
build:orin-nano --experimental_disable_external_package

# ARMv7 build for BeagleBone Black
build:bbb --platforms=//platforms/bbb:bbb_platform
build:bbb --extra_toolchains=//toolchains/arm-linux-gnueabihf/bbb:bbb_cc_toolchain
build:bbb --spawn_strategy=local
build:bbb --experimental_disable_external_package

# Host build (x86_64)
build:host --platforms=//toolchains:linux_x86_64

# Release builds with optimizations
build:release --compilation_mode=opt
build:release --strip=always

# Combined configs
build:release-orin-nano --config=orin-nano
build:release-orin-nano --config=release

build:release-bbb --config=bbb
build:release-bbb --config=release

build:release-host --config=host
build:release-host --config=release
